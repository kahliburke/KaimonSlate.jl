/Manifest.toml
/examples/Manifest.toml
/docs/build/
*.cov
.DS_Store
/.vscode/

# editor swap files
*.swp
*.swo
.*.swp
.*.swo

# Only README.md belongs at the repo root; every other root-level *.md is scratch
# (planning / design / handoff / spec docs). Real documentation lives under docs/.
/*.md
!/README.md

# CM6 bundle build (node deps; the built artifact is committed under src/assets/js/)
build/cm6/node_modules/
build/cm6/package-lock.json

# Machine-local: Julia local prefs + per-project agent config (not package source)
/LocalPreferences.toml
/.claude/

# Standalone-expand artifacts (a single-source .jl expanded into a reproducible project tree)
*.standalone.jl
*.standalone.expanded/
/test_thought/

# Isolated per-worktree hub state (dev/hub.jl) and standalone-run state under a notebook folder
.kaimonslate-dev/
.kaimonslate/
