<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{{ title }}</title>
<style>
:root {
  --bg: #0d1120; --bg2: #141828; --bg3: #1a1e2e; --border: #2a2e40;
  --text: #d4d8e8; --dim: #6a7090; --accent: #569cd6; --green: #56d364;
  --red: #e57575; --gold: #ffd700;
}
* { box-sizing: border-box; }
body { background: var(--bg); color: var(--text);
       font-family: 'Segoe UI', system-ui, sans-serif; line-height: 1.6;
       margin: 0; padding: 0; }
.page { max-width: 980px; margin: 0 auto; padding: 32px 24px; }
h1, h2, h3 { color: #fff; }
a { color: var(--accent); }
code, pre { font-family: 'Cascadia Code','Fira Code',ui-monospace,monospace; }
.md { margin: 18px 0; }
.md h1 { font-size: 1.9rem; border-bottom: 1px solid var(--border); padding-bottom: .3em; }
.md h2 { font-size: 1.35rem; }
.md table { border-collapse: collapse; margin: 10px 0; }
.md th, .md td { border: 1px solid var(--border); padding: 4px 12px; }
.md th { background: var(--bg3); }
.md code { background: var(--bg3); padding: 1px 5px; border-radius: 4px; font-size: 0.9em; }
.cell { background: var(--bg2); border: 1px solid var(--border);
        border-left: 3px solid var(--accent); border-radius: 8px;
        margin: 14px 0; overflow: hidden; }
.cell.errored { border-left-color: var(--red); }
.cell .src { margin: 0; padding: 12px 14px; background: var(--bg3);
             color: var(--text); font-size: 0.86rem; overflow-x: auto;
             white-space: pre-wrap; }
.out, .val, .err { padding: 10px 14px; border-top: 1px solid var(--border);
                   font-size: 0.84rem; }
.out pre, .val pre, .err pre { margin: 0; white-space: pre-wrap; overflow-x: auto; }
.out { color: var(--dim); }
.val { color: var(--green); }
.err { color: var(--red); background: rgba(229, 117, 117, 0.06); }
.dispwrap { padding: 10px 14px; border-top: 1px solid var(--border); }
.disp.img img { max-width: 100%; height: auto; border-radius: 4px; display: block; }
.disp.html { overflow-x: auto; }
.disp.html table { border-collapse: collapse; }
.disp.html th, .disp.html td { border: 1px solid var(--border); padding: 3px 8px; }
.foot { color: var(--dim); font-size: 0.78rem; margin-top: 28px;
        border-top: 1px solid var(--border); padding-top: 10px; }
</style>
</head>
<body>
<div class="page">
<h1>{{ title }}</h1>
{% for c in cells %}
{% if c.kind == "md" %}
<div class="md">{{ c.html |> safe }}</div>
{% else %}
<div class="cell {{ c.state }}">
<pre class="src">{{ c.source }}</pre>
{% if c.stdout != "" %}<div class="out"><pre>{{ c.stdout }}</pre></div>{% end %}
{% if c.value != "" %}<div class="val"><pre>{{ c.value }}</pre></div>{% end %}
{% if c.display != "" %}<div class="dispwrap">{{ c.display |> safe }}</div>{% end %}
{% if c.error != "" %}<div class="err"><pre>{{ c.error }}</pre></div>{% end %}
</div>
{% end %}
{% end %}
<div class="foot">Generated by the Kaimon report builder · {{ title }}</div>
</div>
</body>
</html>
